# Copy to .env and fill in. Loaded by scripts via python-dotenv.
# Used by tau2 (litellm) for: agent (sanity rollout), user simulator, and NL-assertion judge.

# OpenAI key for gpt-5 (user simulator + NL judge). REQUIRED for sanity rollout.
OPENAI_API_KEY=sk-...

# Models (decision: gpt-5 for both user-sim and NL judge; overrides tau2 default gpt-4.1).
TAU2_USER_MODEL=gpt-5
TAU2_AGENT_MODEL=gpt-5
TAU2_NL_JUDGE_MODEL=gpt-5

# Optional: OpenAI-compatible base url (leave unset for real OpenAI).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Local model path (downloaded separately) — used in stage1+ for the policy.
QWEN3_8B_PATH=/home/yzs/ckpts/Qwen3-8B
