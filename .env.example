# Copy to .env and fill in. Loaded by scripts via python-dotenv and by
# verl/Hydra configs via ${oc.env:VAR}. This is the ONLY place machine paths live.

# --- secrets ---
# OpenAI key for gpt-5 (user simulator + NL judge). REQUIRED for sanity rollout.
OPENAI_API_KEY=sk-...
# Optional OpenAI-compatible base url (e.g. a proxy). Leave unset for real OpenAI.
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- models (decision: gpt-5 for user-sim, agent-sanity, and NL judge) ---
TAU2_USER_MODEL=gpt-5
TAU2_AGENT_MODEL=gpt-5
TAU2_NL_JUDGE_MODEL=gpt-5

# --- conda env (a clone of a working verl env) ---
TAU2_ENV=tau2verl

# --- machine paths ---
# Local Qwen3-8B checkpoint (policy model, stage 1+). Downloaded separately.
QWEN3_8B_PATH=./ckpts/Qwen3-8B
# Third-party submodules default to inside the repo; override only if elsewhere.
# TAU2_DIR=third_party/tau2-bench
# VERL_DIR=third_party/verl
# Experiment outputs.
# OUTPUT_DIR=outputs
